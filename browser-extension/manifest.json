{
  "manifest_version": 3,
  "name": "Legalassist-AI Precedent Highlighter",
  "version": "1.0",
  "description": "Automatically highlights legal precedents and case citations in web pages.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Legalassist Precedent Highlighter"
  }
}
